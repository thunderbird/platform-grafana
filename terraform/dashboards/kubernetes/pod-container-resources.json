      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Filesystem Reads",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum by (container) (rate(container_fs_reads_bytes_total{container!=\"\",container!=\"POD\",namespace=~\"$namespace\",pod=~\"$pod\"}[5m]))",
          "legendFormat": "{{container}}",
